---
import ApiCode from "../components/ApiCode.astro";
import ModelCards from "../components/ModelCards.astro";
import PricingTable from "../components/PricingTable.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";

const navItems = [
  { label: "Models", href: "#models" },
  { label: "Pricing", href: "#pricing" },
  { label: "Docs", href: siteConfig.docsHref }
];

const stats = [
  { value: "OpenAI", label: "Compatible API" },
  { value: "USD", label: "No Chinese account" },
  { value: "1 key", label: "Every model" },
  { value: "Stream", label: "Server-sent events" }
];

const steps = [
  {
    n: "01",
    title: "Create your account",
    body: "Sign up with email in under a minute. No company details, no sales call."
  },
  {
    n: "02",
    title: "Add credit",
    body: "Top up in USD with a redeem code. Your balance is shared across every model."
  },
  {
    n: "03",
    title: "Call the API",
    body: "Point your OpenAI SDK at one base URL and ship. Switching models is one line."
  }
];

const valueProps = [
  {
    title: "Only models that earn it",
    body: "We drop what underperforms and keep what actually ships. No noise, no dead SKUs."
  },
  {
    title: "Priced to keep",
    body: "Qwen and DeepSeek at economics that beat the frontier labs, so heavy usage stays affordable."
  },
  {
    title: "One key, one bill",
    body: "No juggling provider accounts, no Chinese cloud signup. One balance covers every model."
  }
];

const privacyPoints = [
  {
    title: "Transparent routing",
    body: "Requests reach the Glideflow gateway, get authenticated and metered, then forward to the model provider you choose."
  },
  {
    title: "Built for indie workloads",
    body: "Prototypes, coding tools, side projects, and early products where practical cost beats enterprise procurement."
  },
  {
    title: "Not for regulated data",
    body: "Do not send medical, financial, or government data unless your own review approves the full provider chain."
  }
];

const faqs = [
  {
    question: "Why only Chinese models?",
    answer:
      "Right now they are the best price for performance on the market, and reaching them from outside China is needlessly hard. Glideflow fixes that."
  },
  {
    question: "How is this different from OpenRouter?",
    answer:
      "OpenRouter is a 400-model marketplace. Glideflow is a curated set of Chinese models, tuned and priced, behind one key. Fewer decisions, faster shipping."
  },
  {
    question: "Do I need a Chinese account?",
    answer:
      "No. No Chinese phone number, Alipay, or ID. Sign up, pay in USD, and call the API."
  },
  {
    question: "Is it really OpenAI-compatible?",
    answer:
      "Yes. Point the official OpenAI SDK at our base URL and your existing code works, with no rewrites."
  },
  {
    question: "What happens to my data?",
    answer:
      "Requests pass through our gateway to the upstream provider you pick. That flow is documented so you decide what belongs here."
  }
];

const heroCode = `from openai import OpenAI

client = OpenAI(
    api_key="sk-...",
    base_url="${siteConfig.apiBaseUrl}",
)

r = client.chat.completions.create(
    model="${siteConfig.models[0].id}",
    messages=[{"role": "user", "content": "Hello"}],
)`;
---

<BaseLayout>
  <main class="bg-[#f7f8fb] text-[#0c0f0e] dark:bg-[#080a09] dark:text-[#f4f7f5]">
    <!-- NAV -->
    <header class="sticky top-0 z-40 border-b border-black/8 bg-[#f7f8fb]/80 backdrop-blur-md dark:border-white/8 dark:bg-[#080a09]/80">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5">
        <a href="/" class="flex items-center gap-2.5 font-semibold no-underline text-[#0c0f0e] dark:text-white">
          <img src="/brand/avatar.svg" alt={siteConfig.brandName} width="30" height="30" class="h-7 w-7 rounded-lg" />
          <span class="text-[15px]">{siteConfig.brandName}</span>
        </a>
        <nav class="hidden items-center gap-7 text-sm text-black/64 dark:text-white/64 md:flex" aria-label="Primary">
          {navItems.map((item) => (
            <a class="transition-colors hover:text-black dark:hover:text-white" href={item.href}>{item.label}</a>
          ))}
        </nav>
        <div class="flex items-center gap-2.5">
          <a
            href={siteConfig.loginHref}
            class="hidden text-sm font-medium text-black/70 transition-colors hover:text-black dark:text-white/70 dark:hover:text-white sm:inline-flex"
          >
            Sign in
          </a>
          <a
            href={siteConfig.ctaHref}
            class="inline-flex h-10 items-center justify-center rounded-xl bg-[#0c0f0e] px-4 text-sm font-semibold text-white transition-all hover:bg-[#1c2a26] active:translate-y-px dark:bg-emerald-300 dark:text-[#06140f] dark:hover:bg-emerald-200"
          >
            Get Started
          </a>
        </div>
      </div>
    </header>

    <!-- HERO -->
    <section class="relative overflow-hidden border-b border-black/8 dark:border-white/8">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.5] dark:opacity-30" aria-hidden="true">
        <div class="h-full w-full bg-[linear-gradient(to_right,rgba(16,185,129,.10)_1px,transparent_1px),linear-gradient(to_bottom,rgba(16,185,129,.10)_1px,transparent_1px)] bg-[size:54px_54px]"></div>
      </div>

      <div class="relative mx-auto grid max-w-6xl items-center gap-12 px-5 pt-16 pb-20 lg:grid-cols-[1.05fr_0.95fr] lg:pt-24 lg:pb-28">
        <div class="reveal">
          <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-emerald-500/25 bg-emerald-400/10 px-3 py-1 text-[13px] font-semibold text-emerald-700 dark:text-emerald-300">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            The curated gateway to Chinese AI models
          </p>
          <h1 class="text-balance text-4xl font-semibold leading-[1.05] tracking-tight text-[#0c0f0e] dark:text-white sm:text-5xl lg:text-6xl">
            You don't need 400 models.<br />You need the right Chinese ones.
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-8 text-black/64 dark:text-white/68">
            China's top models, without the Chinese cloud. Run DeepSeek, Qwen, and GLM through one OpenAI-compatible API, billed in USD.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href={siteConfig.ctaHref}
              class="inline-flex min-h-[3.25rem] items-center justify-center rounded-xl bg-[#0c0f0e] px-7 text-[15px] font-semibold text-white transition-all hover:bg-[#1c2a26] active:translate-y-px dark:bg-emerald-300 dark:text-[#06140f] dark:hover:bg-emerald-200"
            >
              Get Started
            </a>
            <a
              href="#models"
              class="inline-flex min-h-[3.25rem] items-center justify-center rounded-xl border border-black/14 bg-white/70 px-7 text-[15px] font-semibold text-[#0c0f0e] transition-all hover:border-black/30 active:translate-y-px dark:border-white/16 dark:bg-white/[0.06] dark:text-white dark:hover:border-white/35"
            >
              Explore models
            </a>
          </div>
        </div>

        <div class="reveal" data-d="1">
          <figure class="overflow-hidden rounded-2xl border border-white/10 bg-[#06120e] shadow-[0_30px_80px_-20px_rgba(0,0,0,0.45)]">
            <figcaption class="flex items-center gap-2 border-b border-white/10 bg-white/[0.04] px-4 py-3">
              <span class="flex gap-1.5" aria-hidden="true">
                <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
              </span>
              <span class="ml-1 font-mono text-xs text-emerald-300/80">quickstart.py</span>
            </figcaption>
            <pre class="overflow-x-auto px-5 py-5 font-mono text-[13px] leading-7 text-[#d8fff2]"><code>{heroCode}</code></pre>
            <div class="border-t border-white/10 bg-emerald-400/[0.06] px-5 py-3 font-mono text-xs text-emerald-300">{siteConfig.apiBaseUrl}</div>
          </figure>
        </div>
      </div>
    </section>

    <!-- STATS BAND -->
    <section class="border-b border-black/8 bg-white dark:border-white/8 dark:bg-[#0a0d0c]">
      <div class="mx-auto grid max-w-6xl grid-cols-2 gap-px overflow-hidden px-5 md:grid-cols-4">
        {stats.map((s) => (
          <div class="reveal px-2 py-8">
            <div class="text-3xl font-semibold tracking-tight text-[#0c0f0e] dark:text-white">{s.value}</div>
            <div class="mt-1 text-sm text-black/55 dark:text-white/55">{s.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- MODELS -->
    <section id="models" class="border-b border-black/8 dark:border-white/8">
      <div class="mx-auto max-w-6xl px-5 py-20 sm:py-24">
        <div class="reveal max-w-2xl">
          <h2 class="text-3xl font-semibold tracking-tight text-[#0c0f0e] dark:text-white sm:text-4xl">
            The Chinese models worth shipping on
          </h2>
          <p class="mt-4 text-lg leading-8 text-black/60 dark:text-white/64">
            We keep the models that earn their place, tune the pricing, and put them behind one key. No 400-model maze.
          </p>
        </div>
        <div class="mt-10">
          <ModelCards />
        </div>
      </div>
    </section>

    <!-- VALUE: switch models in one line -->
    <section class="border-b border-black/8 bg-white dark:border-white/8 dark:bg-[#0a0d0c]">
      <div class="mx-auto grid max-w-6xl items-center gap-12 px-5 py-20 sm:py-24 lg:grid-cols-2">
        <div class="reveal">
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.14em] text-emerald-700 dark:text-emerald-300">Curated, not crowded</p>
          <h2 class="text-3xl font-semibold tracking-tight text-[#0c0f0e] dark:text-white sm:text-4xl">
            You don't need a 400-model maze
          </h2>
          <p class="mt-4 max-w-lg text-lg leading-8 text-black/60 dark:text-white/64">
            OpenRouter hands you 400 models and a search bar. Glideflow hands you the Chinese models actually worth using, priced to keep, behind one familiar key. Less choosing, more shipping.
          </p>
          <ul class="mt-8 space-y-4">
            {valueProps.map((v) => (
              <li class="reveal flex gap-3">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-500"></span>
                <div>
                  <div class="font-semibold text-[#0c0f0e] dark:text-white">{v.title}</div>
                  <p class="mt-1 text-sm leading-6 text-black/58 dark:text-white/58">{v.body}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal" data-d="1">
          <figure class="overflow-hidden rounded-2xl border border-white/10 bg-[#06120e]">
            <figcaption class="border-b border-white/10 bg-white/[0.04] px-4 py-3 font-mono text-xs text-emerald-300/80">switch.py</figcaption>
            <pre class="overflow-x-auto px-5 py-5 font-mono text-[13px] leading-7 text-[#d8fff2]"><code>{`# one client, many models
for model in [
    "qwen3.5-plus",
    "deepseek-v4-flash",
    "minimax-m3",
]:
    client.chat.completions.create(
        model=model,
        messages=msgs,
    )`}</code></pre>
          </figure>
        </div>
      </div>
    </section>

    <!-- PRICE / PERFORMANCE -->
    <section id="pricing" class="border-b border-black/8 dark:border-white/8">
      <div class="mx-auto max-w-6xl px-5 py-20 sm:py-24">
        <div class="reveal max-w-2xl">
          <h2 class="text-3xl font-semibold tracking-tight text-[#0c0f0e] dark:text-white sm:text-4xl">
            Price and performance, side by side
          </h2>
          <p class="mt-4 text-lg leading-8 text-black/60 dark:text-white/64">
            The same OpenAI request shape, priced per 1 million tokens in USD. Home models are public picks, console models expand coverage.
          </p>
        </div>
        <div class="reveal mt-10">
          <div class="mt-5">
            <PricingTable />
          </div>
        </div>
      </div>
    </section>

    <!-- ONBOARDING STEPS -->
    <section class="border-b border-black/8 bg-white dark:border-white/8 dark:bg-[#0a0d0c]">
      <div class="mx-auto max-w-6xl px-5 py-20 sm:py-24">
        <div class="reveal max-w-2xl">
          <h2 class="text-3xl font-semibold tracking-tight text-[#0c0f0e] dark:text-white sm:text-4xl">
            From zero to first call
          </h2>
        </div>
        <div class="mt-10 grid gap-px overflow-hidden rounded-2xl border border-black/10 dark:border-white/10 md:grid-cols-3">
          {steps.map((s) => (
            <div class="reveal bg-[#f7f8fb] p-7 dark:bg-[#0c100e]">
              <div class="font-mono text-sm text-emerald-700 dark:text-emerald-300">{s.n}</div>
              <h3 class="mt-3 text-lg font-semibold text-[#0c0f0e] dark:text-white">{s.title}</h3>
              <p class="mt-2 text-sm leading-6 text-black/58 dark:text-white/58">{s.body}</p>
            </div>
          ))}
        </div>
        <div class="reveal mt-8">
          <a
            href={siteConfig.ctaHref}
            class="inline-flex min-h-[3.25rem] items-center justify-center rounded-xl bg-[#0c0f0e] px-7 text-[15px] font-semibold text-white transition-all hover:bg-[#1c2a26] active:translate-y-px dark:bg-emerald-300 dark:text-[#06140f] dark:hover:bg-emerald-200"
          >
            Get Started
          </a>
        </div>
      </div>
    </section>

    <!-- QUICK START CODE -->
    <section class="border-b border-black/8 dark:border-white/8">
      <div class="mx-auto max-w-6xl px-5 py-20 sm:py-24">
        <div class="reveal max-w-2xl">
          <h2 class="text-3xl font-semibold tracking-tight text-[#0c0f0e] dark:text-white sm:text-4xl">
            Drop it into your stack
          </h2>
          <p class="mt-4 text-lg leading-8 text-black/60 dark:text-white/64">
            Three ways in, all OpenAI-compatible. Copy, paste your key, ship.
          </p>
        </div>
        <div class="reveal mt-8">
          <ApiCode />
        </div>
      </div>
    </section>

    <!-- PRIVACY -->
    <section class="border-b border-black/8 bg-white dark:border-white/8 dark:bg-[#0a0d0c]">
      <div class="mx-auto max-w-6xl px-5 py-20 sm:py-24">
        <div class="reveal max-w-2xl">
          <h2 class="text-3xl font-semibold tracking-tight text-[#0c0f0e] dark:text-white sm:text-4xl">
            Clear about where requests go
          </h2>
          <p class="mt-4 text-lg leading-8 text-black/60 dark:text-white/64">
            Glideflow is for developers who value cost and compatibility, and who choose what data is right for third-party routing.
          </p>
        </div>
        <div class="mt-10 grid gap-4 md:grid-cols-3">
          {privacyPoints.map((p) => (
            <article class="reveal rounded-2xl border border-black/10 bg-[#f7f8fb] p-6 dark:border-white/10 dark:bg-white/[0.03]">
              <h3 class="font-semibold text-[#0c0f0e] dark:text-white">{p.title}</h3>
              <p class="mt-3 text-sm leading-6 text-black/60 dark:text-white/60">{p.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="border-b border-black/8 dark:border-white/8">
      <div class="mx-auto grid max-w-6xl gap-10 px-5 py-20 sm:py-24 lg:grid-cols-[0.8fr_1.2fr]">
        <div class="reveal">
          <h2 class="text-3xl font-semibold tracking-tight text-[#0c0f0e] dark:text-white sm:text-4xl">
            Straight answers
          </h2>
        </div>
        <div class="reveal divide-y divide-black/10 rounded-2xl border border-black/10 bg-white dark:divide-white/10 dark:border-white/10 dark:bg-white/[0.03]">
          {faqs.map((f) => (
            <details class="group p-6">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-semibold text-[#0c0f0e] dark:text-white">
                {f.question}
                <span class="text-xl leading-none text-emerald-600 transition-transform group-open:rotate-45 dark:text-emerald-300">+</span>
              </summary>
              <p class="mt-3 text-sm leading-7 text-black/60 dark:text-white/60">{f.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="border-b border-black/8 dark:border-white/8">
      <div class="mx-auto max-w-6xl px-5 py-20 sm:py-24">
        <div class="reveal relative overflow-hidden rounded-3xl border border-emerald-500/20 bg-[#06120e] px-7 py-14 text-center sm:px-12">
          <div class="pointer-events-none absolute inset-0 opacity-40" aria-hidden="true">
            <div class="h-full w-full bg-[radial-gradient(circle_at_50%_-20%,rgba(16,185,129,.35),transparent_60%)]"></div>
          </div>
          <h2 class="relative text-3xl font-semibold tracking-tight text-white sm:text-4xl">Ship on Chinese models today</h2>
          <p class="relative mx-auto mt-4 max-w-xl text-lg leading-8 text-white/68">
            Create an account, add credit, and make your first call in minutes.
          </p>
          <div class="relative mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a
              href={siteConfig.ctaHref}
              class="inline-flex min-h-[3.25rem] items-center justify-center rounded-xl bg-emerald-300 px-7 text-[15px] font-semibold text-[#06140f] transition-all hover:bg-emerald-200 active:translate-y-px"
            >
              Get Started
            </a>
            <a
              href={siteConfig.docsHref}
              class="inline-flex min-h-[3.25rem] items-center justify-center rounded-xl border border-white/18 px-7 text-[15px] font-semibold text-white transition-all hover:border-white/40 active:translate-y-px"
            >
              Read the docs
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-[#06120e] py-12 text-white">
      <div class="mx-auto flex max-w-6xl flex-col gap-6 px-5 md:flex-row md:items-center md:justify-between">
        <div class="flex items-center gap-2.5">
          <img src="/brand/avatar.svg" alt={siteConfig.brandName} width="28" height="28" class="h-7 w-7 rounded-lg" />
          <div>
            <p class="font-semibold">{siteConfig.brandName}</p>
            <p class="text-sm text-white/55">The curated gateway to Chinese AI models.</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-white/64">
          <a class="hover:text-white" href="#models">Models</a>
          <a class="hover:text-white" href="#pricing">Pricing</a>
          <a class="hover:text-white" href={siteConfig.docsHref}>Docs</a>
          <a class="hover:text-white" href={siteConfig.loginHref}>Sign in</a>
          <a class="hover:text-white" href={`mailto:${siteConfig.supportEmail}`}>{siteConfig.supportEmail}</a>
          <a class="hover:text-white" href={siteConfig.termsHref}>Terms</a>
        </div>
      </div>
    </footer>
  </main>

  <style>
    .hero-glow {
      position: absolute;
      inset: -20% -10% auto -10%;
      height: 480px;
      background: radial-gradient(60% 100% at 30% 0%, rgba(16, 185, 129, 0.16), transparent 70%);
      pointer-events: none;
    }
    @media (prefers-reduced-motion: no-preference) {
      .reveal {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal.in {
        opacity: 1;
        transform: none;
      }
      .reveal[data-d="1"] { transition-delay: 0.08s; }
      .reveal[data-d="2"] { transition-delay: 0.16s; }
    }
  </style>

  <script>
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("in");
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: "0px 0px -8% 0px" }
    );
    document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
  </script>
</BaseLayout>
