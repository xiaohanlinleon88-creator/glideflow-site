---
import "../styles/global.css";
import { siteConfig } from "../config/site";

const {
  title = `${siteConfig.brandName} - OpenAI-compatible models for practical budgets`,
  description = siteConfig.description
} = Astro.props;

const canonical = new URL(Astro.url.pathname, `https://${siteConfig.domain}`).toString();
const showComplianceFooter = Astro.url.pathname === "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07110f" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
  </head>
  <body>
    <slot />
    {
      showComplianceFooter && (
        <footer class="border-t border-white/10 bg-[#06120e] py-5 text-sm text-white/60">
          <nav class="mx-auto flex max-w-6xl flex-wrap gap-x-6 gap-y-2 px-5" aria-label="Compliance footer">
            <a class="hover:text-white" href={siteConfig.docsHref}>Docs</a>
            <a class="hover:text-white" href={siteConfig.termsHref}>Terms</a>
            <a class="hover:text-white" href={siteConfig.privacyHref}>Privacy</a>
            <a class="hover:text-white" href={siteConfig.refundHref}>Refund</a>
            <a class="hover:text-white" href={siteConfig.aupHref}>AUP</a>
            <a class="hover:text-white" href={siteConfig.contactHref}>Contact</a>
          </nav>
        </footer>
      )
    }
  </body>
</html>
