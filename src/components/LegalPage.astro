---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";

const {
  title,
  description,
  eyebrow = "Legal",
  updated = "June 30, 2026"
}: {
  title: string;
  description: string;
  eyebrow?: string;
  updated?: string;
} = Astro.props;

const legalLinks = [
  { label: "Terms", href: siteConfig.termsHref },
  { label: "Privacy", href: siteConfig.privacyHref },
  { label: "Refund", href: siteConfig.refundHref },
  { label: "AUP", href: siteConfig.aupHref }
];
---

<BaseLayout title={`${title} | ${siteConfig.brandName}`} description={description}>
  <main class="min-h-screen bg-[#080a09] text-[#f4f7f5]">
    <header class="border-b border-white/10 bg-[#080a09]/90">
      <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-5">
        <a href="/" class="flex items-center gap-2.5 font-semibold text-white no-underline">
          <img src="/brand/avatar.svg" alt={siteConfig.brandName} width="30" height="30" class="h-7 w-7 rounded-lg" />
          <span>{siteConfig.brandName}</span>
        </a>
        <nav class="hidden items-center gap-6 text-sm text-white/64 sm:flex" aria-label="Legal navigation">
          <a class="hover:text-white" href={siteConfig.docsHref}>Docs</a>
          <a class="hover:text-white" href={siteConfig.loginHref}>Sign in</a>
          <a class="hover:text-white" href={siteConfig.contactHref}>Contact</a>
        </nav>
      </div>
    </header>

    <section class="relative overflow-hidden border-b border-white/10">
      <div class="pointer-events-none absolute inset-0 opacity-30" aria-hidden="true">
        <div class="h-full w-full bg-[linear-gradient(to_right,rgba(16,185,129,.14)_1px,transparent_1px),linear-gradient(to_bottom,rgba(16,185,129,.14)_1px,transparent_1px)] bg-[size:54px_54px]"></div>
      </div>
      <div class="relative mx-auto max-w-5xl px-5 py-16 sm:py-20">
        <p class="mb-4 inline-flex rounded-full border border-emerald-400/25 bg-emerald-400/10 px-3 py-1 text-sm font-semibold text-emerald-200">
          {eyebrow}
        </p>
        <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-white sm:text-5xl">{title}</h1>
        <p class="mt-5 max-w-3xl text-base leading-7 text-white/66">{description}</p>
        <p class="mt-5 text-sm text-white/46">Last updated: {updated}</p>
      </div>
    </section>

    <section class="mx-auto grid max-w-5xl gap-8 px-5 py-12 lg:grid-cols-[220px_1fr] lg:py-16">
      <aside class="lg:sticky lg:top-6 lg:self-start">
        <nav class="grid gap-2 rounded-lg border border-white/10 bg-white/[0.04] p-3 text-sm" aria-label="Legal pages">
          {legalLinks.map((link) => (
            <a class="rounded-md px-3 py-2 text-white/68 transition hover:bg-white/[0.06] hover:text-white" href={link.href}>
              {link.label}
            </a>
          ))}
        </nav>
      </aside>

      <article class="legal-body rounded-lg border border-white/10 bg-white/[0.04] p-6 text-white/72 sm:p-8">
        <slot />
      </article>
    </section>

    <footer class="border-t border-white/10 py-10">
      <div class="mx-auto flex max-w-5xl flex-col gap-5 px-5 md:flex-row md:items-center md:justify-between">
        <p class="text-sm text-white/50">{siteConfig.brandName} provides OpenAI-compatible model access for developers.</p>
        <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-white/60">
          <a class="hover:text-white" href={siteConfig.docsHref}>Docs</a>
          <a class="hover:text-white" href={siteConfig.termsHref}>Terms</a>
          <a class="hover:text-white" href={siteConfig.privacyHref}>Privacy</a>
          <a class="hover:text-white" href={siteConfig.refundHref}>Refund</a>
          <a class="hover:text-white" href={siteConfig.aupHref}>AUP</a>
          <a class="hover:text-white" href={siteConfig.contactHref}>Contact</a>
        </div>
      </div>
    </footer>
  </main>

  <style>
    .legal-body :global(h2) {
      margin: 2rem 0 0.75rem;
      color: white;
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: 0;
    }

    .legal-body :global(h2:first-child) {
      margin-top: 0;
    }

    .legal-body :global(p),
    .legal-body :global(li) {
      line-height: 1.75;
    }

    .legal-body :global(p) {
      margin: 0.8rem 0;
    }

    .legal-body :global(ul) {
      margin: 0.75rem 0 1.25rem;
      padding-left: 1.25rem;
    }

    .legal-body :global(a) {
      color: #6ee7b7;
      text-underline-offset: 0.18em;
    }
  </style>
</BaseLayout>
