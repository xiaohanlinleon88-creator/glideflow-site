---
import { formatUsdPerMillion, siteConfig } from "../config/site";
---

<div class="model-grid">
  {siteConfig.models.map((model) => (
    <article class="model-card">
      <div>
        <p>{model.bestFor}</p>
        <h3>{model.name}</h3>
        <code>{model.id}</code>
      </div>
      <p class="model-desc">{model.description}</p>
      <dl>
        <div>
          <dt>Input</dt>
          <dd>{formatUsdPerMillion(model.inputPrice)}</dd>
        </div>
        <div>
          <dt>Output</dt>
          <dd>{formatUsdPerMillion(model.outputPrice)}</dd>
        </div>
      </dl>
    </article>
  ))}
</div>

<style>
  .model-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .model-card {
    display: flex;
    min-height: 250px;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    border-radius: 8px;
    padding: 18px;
    background: color-mix(in srgb, Canvas 94%, currentColor 6%);
  }

  .model-card p:first-child {
    margin: 0 0 10px;
    color: #0f766e;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .model-card h3 {
    margin: 0 0 6px;
    font-size: 1.12rem;
  }

  .model-card code {
    font-family: var(--font-mono, "SFMono-Regular", Consolas, monospace);
    font-size: 0.78rem;
    color: color-mix(in srgb, currentColor 66%, transparent);
  }

  .model-desc {
    margin: 18px 0;
    color: color-mix(in srgb, currentColor 76%, transparent);
    line-height: 1.6;
  }

  .model-card dl {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin: 0;
  }

  .model-card dt {
    color: color-mix(in srgb, currentColor 58%, transparent);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .model-card dd {
    margin: 4px 0 0;
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .model-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .model-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
